<project namespace="palm::models">
    <class name="User" table="users" autoIncrementID="true">
        <property name="id" type="int64"/>
        <property name="user_id" type="int64"/>
        <property name="key" type="string"/>
        <property name="value" type="string"/>
        <property name="salt" type="string"/>
        <property name="version" type="int64"/>
        <property name="created_at" type="dateTime"/>
        <property name="updated_at" type="dateTime"/>
    </class>
    <class name="Log" table="logs" autoIncrementID="true">
        <property name="id" type="int64"/>
        <property name="created_at" type="dateTime"/>
    </class>
    <class name="Group" table="groups" autoIncrementID="true">
        <property name="id" type="int64"/>
        <property name="version" type="int64"/>
        <property name="created_at" type="dateTime"/>
        <property name="updated_at" type="dateTime"/>
    </class>
    <class name="GroupUser" table="group_users" autoIncrementID="true">
        <property name="id" type="int64"/>
        <property name="version" type="int64"/>
        <property name="created_at" type="dateTime"/>
        <property name="updated_at" type="dateTime"/>
    </class>
</project>
