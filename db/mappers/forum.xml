<project namespace="palm::models">
    <class name="ForumTopic" table="forum_topics" autoIncrementID="true">
        <property name="id" type="int64"/>
        <property name="version" type="int64"/>
        <property name="created_at" type="dateTime"/>
        <property name="updated_at" type="dateTime"/>
    </class>
    <class name="ForumTopicTag" table="forum_topics_tags" autoIncrementID="true">
        <property name="id" type="int64"/>
        <property name="version" type="int64"/>
        <property name="created_at" type="dateTime"/>
        <property name="updated_at" type="dateTime"/>
    </class>
    <class name="ForumPost" table="forum_posts" autoIncrementID="true">
        <property name="id" type="int64"/>
        <property name="version" type="int64"/>
        <property name="created_at" type="dateTime"/>
        <property name="updated_at" type="dateTime"/>
    </class>
</project>
