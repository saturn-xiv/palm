triple=arm-linux-gnueabihf

[settings]
os=Linux
arch=armv7hf
compiler=clang
compiler.version=13
compiler.libcxx=libstdc++11
build_type=Release

[env]
CC=clang-13
CXX=clang++-13
CONAN_SYSROOT=/user/$triple
CONAN_CFLAGS="-target $triple -ccc-gcc-name $triple-gcc-10"
CONAN_CXXFLAGS="-target $triple -ccc-gcc-name $triple-gcc-10"
CONAN_EXELINKFLAGS="--ld-path=ld.lld-13"
