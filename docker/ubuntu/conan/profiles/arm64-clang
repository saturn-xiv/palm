target=aarch64-linux-gnu

[settings]
os=Linux
arch=armv7hf
compiler=clang
compiler.version=13
compiler.libcxx=libstdc++11
compiler.cppstd=20
build_type=Release
boost:compiler=gcc
boost:compiler.cppstd=11
boost:compiler.version=10
boost:compiler.libcxx=libstdc++11

[env]
CHOST=$target
CC=clang-13
CXX=clang++-13
CFLAGS="-target $target -ccc-gcc-name $target-gcc-10"
CXXFLAGS="-target $target -ccc-gcc-name $target-gcc-10"
LDFLAGS="--ld-path=ld.lld-13"

boost:CC=$target-gcc-10
boost:CXX=$target-g++-10
boost:CFLAGS=""
boost:CXXFLAGS=""
boost:LDFLAGS=""

