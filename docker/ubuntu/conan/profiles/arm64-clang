triple=aarch64-linux-gnu

[settings]
os=Linux
arch=armv8
compiler=clang
compiler.version=13
compiler.libcxx=libstdc++11
compiler.cppstd=20
build_type=Release

[env]
CC=clang-13
CXX=clang++-13
CFLAGS="-target $triple -ccc-gcc-name $triple-gcc-10 --sysroot /user/$triple"
CXXFLAGS="-target $triple -ccc-gcc-name $triple-gcc-10 --sysroot /user/$triple"
LDFLAGS="--ld-path=ld.lld-13"
