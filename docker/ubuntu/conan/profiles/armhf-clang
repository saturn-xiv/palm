triple=arm-linux-gnueabihf

[settings]
os=Linux
arch=armv7hf
compiler=clang
compiler.version=13
compiler.libcxx=libstdc++11
compiler.cppstd=20
build_type=Release

[env]
CC=clang-13
CXX=clang++-13
CHOST=$triple
AR=$triple-ar
AS=$triple-as
RANLIB=$triple-ranlib
LD=$triple-ld
STRIP=$triple-strip
CFLAGS="-ccc-gcc-name $triple-gcc-10"
CXXFLAGS="-ccc-gcc-name $triple-gcc-10"
LDFLAGS="--ld-path=ld.lld-13"
