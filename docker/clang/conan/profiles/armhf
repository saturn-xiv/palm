target=arm-none-linux-gnueabihf
clang_home=/home/deploy/local/clang+llvm-13.0.0-x86_64-linux-gnu-ubuntu-20.04
gcc_home=/home/deploy/local/gcc-arm-10.3-2021.07-x86_64-arm-none-linux-gnueabihf
cflags="-target $target -ccc-gcc-name $gcc_home/bin/$target-gcc --gcc-toolchain=$gcc_home --sysroot=$gcc_home/$target/libc"

[settings]
os=Linux
arch=armv7hf
compiler=clang
compiler.version=13
compiler.libcxx=libstdc++11
compiler.cppstd=17
build_type=Release

boost:compiler=gcc
boost:compiler.cppstd=11
boost:compiler.version=10
boost:compiler.libcxx=libstdc++11

[env]
CHOST=$target
CC=$clang_home/bin/clang
CXX=$clang_home/bin/clang++
CFLAGS=$cflags
CXXFLAGS=$cflags
LDFLAGS="--ld-path=$clang_home/bin/ld.lld"

boost:CC=$gcc_home/bin/$target-gcc
boost:CXX=$gcc_home/bin/$target-g++
boost:CFLAGS=""
boost:CXXFLAGS=""
boost:LDFLAGS=""
