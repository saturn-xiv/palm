target=x86_64-linux-gnu
clang_home=/home/deploy/local/clang+llvm-13.0.0-x86_64-linux-gnu-ubuntu-20.04

[settings]
os=Linux
arch=x86_64
compiler=clang
compiler.version=13
compiler.libcxx=libstdc++11
compiler.cppstd=20
build_type=Release

[env]
CC=$clang_home/bin/clang
CXX=$clang_home/bin/clang++
CFLAGS="-target $target"
CXXFLAGS="-target $target"
LDFLAGS="--ld-path=$clang_home/bin/ld.lld"
